# Используем официальный образ PHP с командной строкой (CLI)
FROM php:8.0-cli

# Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# Копируем ваш PHP-скрипт из репозитория в рабочую директорию
COPY bitrix_handler.php .

# Сообщаем Render, какой порт будет слушать наше приложение
# Render ожидает, что приложение будет слушать порт, переданный в переменной окружения $PORT
EXPOSE $PORT

# Команда для запуска встроенного веб-сервера PHP
# Мы используем переменную $PORT, которую автоматически предоставляет Render
CMD php -S 0.0.0.0:$PORT -t .
